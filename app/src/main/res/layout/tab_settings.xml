<?xml version="1.0" encoding="utf-8"?>
<!-- one line of explanation per control. the long "why" lives in the code comments. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="24dp">

        <!-- ── screen ── -->
        <TextView style="@style/SettingsSection" android:text="SCREEN" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_fill_mode"
            style="@style/SettingRow"
            android:text="Fill the whole screen" />

        <TextView
            style="@style/SettingsHint"
            android:text="Off = letterbox, with black bars." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_night_mode"
            style="@style/SettingButton"
            android:text="Day / night" />

        <TextView
            style="@style/SettingsHint"
            android:text="Dark theme on the dash after sunset." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_video_quality"
            style="@style/SettingButton"
            android:text="Picture quality" />

        <TextView
            style="@style/SettingsHint"
            android:text="Turn it down if your music stutters while riding. Applies on the next connect." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_align"
            style="@style/SettingButton"
            android:text="Picture alignment" />

        <TextView
            style="@style/SettingsHint"
            android:text="Leave centred unless part of the picture is missing at one edge." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_margins"
            style="@style/SettingButton"
            android:text="Screen margins" />

        <TextView
            style="@style/SettingsHint"
            android:text="Keep Android Auto clear of an edge, e.g. the 800NK's pull-down arrow at the top." />

        <!-- ── buttons ── -->
        <TextView style="@style/SettingsSection" android:text="BUTTONS" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_button_mode"
            style="@style/SettingRow"
            android:text="Bike buttons drive Android Auto" />

        <TextView
            style="@style/SettingsHint"
            android:text="Your music player pauses while this is on. Android gives the buttons to one app at a time." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_button_mapping"
            style="@style/SettingButton"
            android:text="Customize buttons" />

        <TextView
            style="@style/SettingsHint"
            android:text="Choose what each button does." />

        <!-- ── sound ── -->
        <TextView style="@style/SettingsSection" android:text="SOUND" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_aa_audio"
            style="@style/SettingRow"
            android:enabled="false"
            android:text="Android Auto audio through the bike" />

        <TextView
            style="@style/SettingsHint"
            android:text="Not built yet. Sound already reaches your helmet from the phone over Bluetooth." />

        <!-- ── connection ── -->
        <TextView style="@style/SettingsSection" android:text="CONNECTION" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_auto_connect"
            style="@style/SettingRow"
            android:text="Connect when the app opens" />

        <TextView
            style="@style/SettingsHint"
            android:text="No QR, no button. Just open it." />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_reconnect"
            style="@style/SettingRow"
            android:text="Rejoin after an ignition cycle" />

        <TextView
            style="@style/SettingsHint"
            android:text="Waits for the bike to come back, then gives up after 2 minutes." />

        <!-- ── advanced ── -->
        <TextView style="@style/SettingsSection" android:text="ADVANCED" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_aa_settings"
            style="@style/SettingButton"
            android:text="Open Android Auto settings" />

        <TextView
            style="@style/SettingsHint"
            android:text="Needs “Add new cars to Android Auto” turned on." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_updates"
            style="@style/SettingButton"
            android:text="Check for updates" />

        <TextView
            style="@style/SettingsHint"
            android:text="Looks on GitHub. Won't work while connected — the bike's Wi-Fi has no internet." />

        <TextView
            android:id="@+id/tv_profile_info"
            style="@style/SettingsHint"
            android:paddingTop="16dp"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
