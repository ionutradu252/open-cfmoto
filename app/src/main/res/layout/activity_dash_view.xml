<?xml version="1.0" encoding="utf-8"?>
<!-- the dash mirrored on the phone, with the phone screen as its touchpad. the SurfaceView is
     resized in code to the bike canvas aspect so nothing skews and taps map one to one. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="Dash view" />

    <FrameLayout
        android:id="@+id/dash_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <SurfaceView
            android:id="@+id/dash_surface"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_dash_hint"
        style="@style/SettingsHint"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        tools:text="Tap, swipe and pinch here to drive Android Auto." />
</LinearLayout>
