<?xml version="1.0" encoding="utf-8"?>
<!--
  Shell: a persistent status header, a swappable tab body, and a bottom nav bar.
  The four tabs are plain <include>s toggled by visibility rather than Fragments, every control
  still lives in MainActivity's view tree, so findViewById keeps working and there is no fragment
  lifecycle to fight with when Google Android Auto recreates this activity mid-hand-off.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Header: name/version, then the glanceable live status. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="v0.1.2" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout style="@style/StatBlock">
                <TextView style="@style/StatLabel" android:text="ANDROID AUTO" />
                <TextView android:id="@+id/tv_stat_aa" style="@style/StatValue" tools:text="● 30 fps" />
            </LinearLayout>

            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatBlock">
                <TextView style="@style/StatLabel" android:text="BIKE" />
                <TextView android:id="@+id/tv_stat_bike" style="@style/StatValue" tools:text="● 1204" />
            </LinearLayout>

            <View style="@style/StatDivider" />

            <LinearLayout style="@style/StatBlock">
                <TextView style="@style/StatLabel" android:text="INPUT" />
                <TextView android:id="@+id/tv_stat_keys" style="@style/StatValue" tools:text="ready" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Tab body -->
    <FrameLayout
        android:id="@+id/tab_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            android:id="@+id/tab_connect"
            layout="@layout/tab_connect"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/tab_control"
            layout="@layout/tab_control"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/tab_settings"
            layout="@layout/tab_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/tab_logs"
            layout="@layout/tab_logs"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav" />
</LinearLayout>
