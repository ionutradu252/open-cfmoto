<?xml version="1.0" encoding="utf-8"?>
<!-- Step-by-step: pair the bike once → connect → ride. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Step 1: pair ── -->
        <com.google.android.material.card.MaterialCardView style="@style/StepCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView style="@style/StepBadge" android:text="1" />
                    <TextView style="@style/StepTitle" android:text="Pair your bike" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_bike_info"
                    style="@style/SettingsHint"
                    android:paddingTop="10dp"
                    tools:text="No bike saved yet." />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_scan_qr"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan bike QR" />

                    <Space android:layout_width="8dp" android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_forget_bike"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forget" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Step 2: the one big button ── -->
        <com.google.android.material.card.MaterialCardView style="@style/StepCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView style="@style/StepBadge" android:text="2" />
                    <TextView style="@style/StepTitle" android:text="Connect" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_connect"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="12dp"
                    android:text="Start Android Auto"
                    android:textSize="17sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_tab_connect"
                    app:iconGravity="textStart"
                    app:iconSize="22dp"
                    app:cornerRadius="22dp" />

                <TextView
                    android:id="@+id/tv_connect_hint"
                    style="@style/SettingsHint"
                    android:paddingTop="10dp"
                    android:gravity="center_horizontal"
                    tools:text="Turn the ignition on first." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Step 3: destination ── -->
        <com.google.android.material.card.MaterialCardView style="@style/StepCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView style="@style/StepBadge" android:text="3" />
                    <TextView style="@style/StepTitle" android:text="Set a destination" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Navigate to…">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_destination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:imeOptions="actionGo"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space android:layout_width="8dp" android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_navigate"
                        style="?attr/materialButtonTonalStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Go" />
                </LinearLayout>

                <TextView
                    style="@style/SettingsHint"
                    android:paddingTop="8dp"
                    android:text="Type it here and Google Maps takes over — the route shows on the dash, no dash interaction needed." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Tutorial: collapsed by default so it doesn't crowd the flow ── -->
        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/row_tutorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="How it works"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tv_tutorial_chevron"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▾"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_tutorial_body"
                    style="@style/SettingsHint"
                    android:visibility="gone"
                    android:paddingTop="12dp"
                    android:text="@string/tutorial_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mirror_start"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mirror phone screen instead" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="made by snaipdefix"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</ScrollView>
