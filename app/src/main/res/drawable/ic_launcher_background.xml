<?xml version="1.0" encoding="utf-8"?>
<!--
  Flat navy, sampled from the logo artwork's own backdrop.

  It matters that this matches: the foreground keys the backdrop out by luminance, so the logo's
  dark internal details — the fairing shadows, the outlines — are transparent and land on this
  colour. Change it and you repaint the inside of the bike.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ic_launcher_bg" />
</shape>
